<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Base Forte Locação — Sistema de Gestão</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
:root{
  --charcoal:#141414;
  --charcoal-2:#232323;
  --steel:#4A4E57;
  --amber:#DB1B16;
  --amber-dark:#B01310;
  --brand-green:#4C9A1C;
  --brand-blue:#1D3F73;
  --concrete:#EDEAE3;
  --concrete-2:#F7F5F0;
  --ink:#1A1A1A;
  --ink-soft:#5B5F66;
  --green:#2F9E6E;
  --red:#D64545;
  --line:#DDD8CE;
  --radius:6px;
}
*{box-sizing:border-box; margin:0; padding:0;}
body{
  font-family:'Inter',sans-serif;
  background:var(--concrete);
  color:var(--ink);
  min-height:100vh;
}
h1,h2,h3,.display{
  font-family:'Oswald',sans-serif;
  font-weight:700;
  letter-spacing:0.02em;
  text-transform:uppercase;
}
.mono{font-family:'JetBrains Mono',monospace;}

/* ---- hazard stripe signature (tricolor, inspirado nas escoras do andaime) ---- */
.hazard{
  height:6px;
  background:repeating-linear-gradient(135deg,
    var(--brand-green) 0 10px,
    var(--amber) 10px 20px,
    var(--brand-blue) 20px 30px);
}

/* ---- layout ---- */
.app{display:flex; min-height:100vh;}
.sidebar{
  width:220px; background:var(--charcoal); color:var(--concrete-2);
  flex-shrink:0; display:flex; flex-direction:column;
}
.brand{
  padding:22px 20px 16px; border-bottom:1px solid #34373B;
}
.brand .display{font-size:26px; color:var(--amber); line-height:1;}
.brand .sub{font-size:11px; color:#9CA0A8; letter-spacing:0.08em; margin-top:2px;}
nav{padding:14px 10px; flex:1;}
nav button{
  display:flex; align-items:center; gap:10px; width:100%;
  background:none; border:none; color:#C9CCD1; text-align:left;
  padding:11px 12px; border-radius:var(--radius); font-size:14px; font-weight:500;
  cursor:pointer; margin-bottom:2px; transition:background .15s;
}
nav button:hover{background:#2C2F34;}
nav button.active{background:var(--amber); color:var(--charcoal); font-weight:700;}
nav .icon{width:18px; text-align:center; font-size:15px;}

.main{flex:1; display:flex; flex-direction:column; min-width:0;}
.topbar{
  background:var(--concrete-2); border-bottom:1px solid var(--line);
  padding:16px 28px; display:flex; align-items:center; justify-content:space-between;
}
.topbar h1{font-size:24px; color:var(--ink);}
.content{padding:26px 28px 60px; overflow-y:auto;}

/* ---- cards / stats ---- */
.grid{display:grid; gap:16px;}
.grid-4{grid-template-columns:repeat(4,1fr);}
.grid-2{grid-template-columns:1fr 1fr;}
@media(max-width:900px){.grid-4{grid-template-columns:repeat(2,1fr);} .grid-2{grid-template-columns:1fr;} .sidebar{width:70px;} .brand .display{display:none;} nav button span.label{display:none;}}

.stat{
  background:var(--concrete-2); border:1px solid var(--line); border-radius:var(--radius);
  padding:16px 18px; position:relative; overflow:hidden;
}
.stat::before{content:''; position:absolute; left:0; top:0; bottom:0; width:4px; background:var(--amber);}
.stat .num{font-family:'JetBrains Mono',monospace; font-size:28px; font-weight:600; color:var(--ink);}
.stat .lbl{font-size:12px; color:var(--ink-soft); text-transform:uppercase; letter-spacing:0.05em; margin-top:2px;}
.stat.warn::before{background:var(--red);}
.stat.ok::before{background:var(--green);}

.panel{
  background:var(--concrete-2); border:1px solid var(--line); border-radius:var(--radius);
  padding:20px; margin-bottom:18px;
}
.panel h2{font-size:19px; margin-bottom:14px; color:var(--ink); display:flex; align-items:center; gap:8px;}
.panel h2 .tag{
  font-family:'JetBrains Mono',monospace; font-size:10px; background:var(--amber); color:var(--charcoal);
  padding:2px 6px; border-radius:3px; text-transform:none; letter-spacing:0;
}

/* ---- forms ---- */
label{display:block; font-size:12px; font-weight:600; color:var(--ink-soft); text-transform:uppercase; letter-spacing:0.04em; margin-bottom:5px;}
input,select,textarea{
  width:100%; padding:9px 11px; border:1px solid var(--line); border-radius:var(--radius);
  font-family:'Inter',sans-serif; font-size:14px; background:#fff; color:var(--ink);
}
input:focus,select:focus,textarea:focus{outline:2px solid var(--amber); outline-offset:1px; border-color:var(--amber);}
.field{margin-bottom:13px;}
.row{display:flex; gap:12px;}
.row > *{flex:1;}

button.btn{
  font-family:'Inter',sans-serif; font-weight:600; font-size:14px; cursor:pointer;
  border:none; border-radius:var(--radius); padding:10px 18px; transition:transform .1s, opacity .15s;
}
button.btn:active{transform:scale(0.98);}
.btn-primary{background:var(--amber); color:var(--charcoal);}
.btn-primary:hover{background:var(--amber-dark);}
.btn-dark{background:var(--charcoal); color:#fff;}
.btn-dark:hover{opacity:0.85;}
.btn-outline{background:none; border:1.5px solid var(--charcoal); color:var(--charcoal);}
.btn-outline:hover{background:var(--charcoal); color:#fff;}
.btn-sm{padding:6px 12px; font-size:12.5px;}
.btn-danger{background:none; color:var(--red); border:1.5px solid var(--red);}

/* ---- table ---- */
table{width:100%; border-collapse:collapse; font-size:13.5px;}
th{
  text-align:left; padding:9px 10px; background:var(--charcoal); color:var(--concrete-2);
  font-family:'Oswald',sans-serif; font-weight:600; text-transform:uppercase; font-size:12px; letter-spacing:0.04em;
}
th:first-child{border-radius:5px 0 0 0;} th:last-child{border-radius:0 5px 0 0;}
td{padding:9px 10px; border-bottom:1px solid var(--line);}
tr:hover td{background:#F2EFE8;}

.badge{
  display:inline-block; padding:3px 9px; border-radius:12px; font-size:11px; font-weight:700;
  text-transform:uppercase; letter-spacing:0.03em;
}
.badge-ok{background:#E1F3EA; color:var(--green);}
.badge-warn{background:#FDEBD3; color:var(--amber-dark);}
.badge-bad{background:#FBE4E4; color:var(--red);}
.badge-neutral{background:#E8E6E0; color:var(--ink-soft);}

.item-row{display:flex; gap:10px; align-items:end; margin-bottom:10px; padding:10px; background:#F7F5F0; border-radius:var(--radius); border:1px dashed var(--line);}
.item-row select, .item-row input{flex:1;}
.item-row .qty{max-width:70px;}
.item-row button{flex-shrink:0;}

.summary-box{
  background:var(--charcoal); color:#fff; border-radius:var(--radius); padding:16px 18px; margin-top:14px;
}
.summary-box .row{justify-content:space-between; margin-bottom:6px; font-size:14px;}
.summary-box .total{font-family:'JetBrains Mono',monospace; font-size:22px; color:var(--amber); font-weight:700;}

.empty{text-align:center; padding:40px 20px; color:var(--ink-soft);}
.empty .display{font-size:20px; color:var(--steel); margin-bottom:6px;}

.toast{
  position:fixed; bottom:20px; right:20px; background:var(--charcoal); color:#fff;
  padding:12px 18px; border-radius:var(--radius); font-size:14px; z-index:999;
  border-left:4px solid var(--amber); box-shadow:0 6px 18px rgba(0,0,0,0.25);
  display:none;
}
.hidden{display:none !important;}
.actions-cell{display:flex; gap:6px;}
.config-note{font-size:12.5px; color:var(--ink-soft); background:#FDEBD3; border:1px solid #F0D19A; padding:10px 12px; border-radius:var(--radius); margin-bottom:16px;}

/* ---- login screen ---- */
.login-wrap{
  min-height:100vh; display:flex; align-items:center; justify-content:center;
  background:var(--charcoal);
}
.login-card{
  width:100%; max-width:360px; background:var(--concrete-2); border-radius:var(--radius);
  padding:32px 30px; box-shadow:0 20px 50px rgba(0,0,0,0.35); position:relative; overflow:hidden;
}
.login-card::before{content:''; position:absolute; left:0; top:0; right:0; height:5px; background:var(--amber);}
.login-card .display{font-size:30px; color:var(--amber); text-align:center; margin-bottom:2px;}
.login-card .sub{font-size:12px; color:var(--ink-soft); text-align:center; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:24px;}
.login-card .field{margin-bottom:14px;}
.login-card button{width:100%; margin-top:6px;}
.login-error{color:var(--red); font-size:13px; margin-top:10px; display:none;}
.logout-btn{
  width:100%; margin:0; padding:9px 12px; border-radius:var(--radius); background:none; border:1px solid #3A3D42;
  color:#9CA0A8; font-size:12.5px; cursor:pointer; text-align:left;
}
.logout-btn:hover{background:#2C2F34; color:#fff;}
.logo-mark{width:64px; height:64px; display:block; margin:0 auto 10px;}
.logo-mark-sm{width:38px; height:38px; margin:0 0 8px;}
.logo-mark-img{width:100%; max-width:220px; height:auto; display:block; margin:0 auto 14px; border-radius:8px;}
.logo-mark-sm-img{width:100%; max-width:150px; height:auto; display:block; margin:0 0 10px; border-radius:6px;}
.dev-signature{
  text-align:center; font-size:10.5px; color:var(--ink-soft); letter-spacing:0.03em;
  margin-top:20px; padding-top:14px; border-top:1px solid var(--line);
}
.sidebar-footer{padding:0 10px 14px;}
.dev-signature-sidebar{
  color:#6B6F76; font-size:9.5px; text-align:left; margin-top:8px; padding:0 2px;
  border-top:none;
}
</style>
</head>
<body>

<div class="login-wrap hidden" id="login-screen">
  <div class="login-card">
    <img class="logo-mark logo-mark-img" src="data:image/jpeg;base64," alt="Base Forte Locação">
    <form id="form-login">
      <div class="field"><label>E-mail</label><input id="login-email" type="email" required autocomplete="username"></div>
      <div class="field"><label>Senha</label><input id="login-senha" type="password" required autocomplete="current-password"></div>
      <button type="submit" class="btn btn-primary">Entrar</button>
      <div class="login-error" id="login-error">E-mail ou senha inválidos.</div>
    </form>
    <div class="dev-signature">Desenvolvido por Foster Engenharia &amp; Construção</div>
  </div>
</div>

<div class="app hidden" id="app-shell">
  <div class="sidebar">
    <div class="brand">
      <img class="logo-mark logo-mark-sm-img" src="data:image/jpeg;base64," alt="Base Forte Locação">
    </div>
    <nav>
      <button class="nav-btn active" data-view="dashboard"><span class="icon">▦</span><span class="label">Dashboard</span></button>
      <button class="nav-btn" data-view="clientes"><span class="icon">◆</span><span class="label">Clientes</span></button>
      <button class="nav-btn" data-view="ferramentas"><span class="icon">▣</span><span class="label">Ferramentas</span></button>
      <button class="nav-btn" data-view="nova-locacao"><span class="icon">＋</span><span class="label">Nova Locação</span></button>
      <button class="nav-btn" data-view="locacoes"><span class="icon">☰</span><span class="label">Locações</span></button>
    </nav>
    <div class="sidebar-footer">
      <button class="logout-btn" id="logout-btn">↩ Sair</button>
      <div class="dev-signature dev-signature-sidebar">Foster Engenharia &amp; Construção</div>
    </div>
  </div>

  <div class="main">
    <div class="hazard"></div>
    <div class="topbar">
      <h1 id="page-title">Dashboard</h1>
    </div>
    <div class="content" id="content"></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
/* ======================================================
   CONFIGURAÇÃO SUPABASE — troque pelos dados do seu projeto
   ====================================================== */
/* ======================================================
   PROTEÇÃO CONTRA TELA EM BRANCO
   ====================================================== */
window.addEventListener('error', function(e){
  console.error('Erro capturado:', e.error || e.message);
  const shell = document.getElementById('app-shell');
  const login = document.getElementById('login-screen');
  if(shell && shell.classList.contains('hidden') && login && login.classList.contains('hidden')){
    login.classList.remove('hidden');
    const errBox = document.getElementById('login-error');
    if(errBox){
      errBox.textContent = 'Ocorreu um erro ao carregar o app: ' + (e.message || 'erro desconhecido') + '. Veja o console (F12) para detalhes.';
      errBox.style.display = 'block';
    }
  }
});

const SUPABASE_URL = 'https://SEU-PROJETO.supabase.co';
const SUPABASE_ANON_KEY = 'SUA-ANON-KEY-AQUI';
let supabaseClient = null;
let supaOk = false;
try{
  if(!SUPABASE_URL.includes('SEU-PROJETO')){
    supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
    supaOk = true;
  }
}catch(e){ console.error(e); }

/* ---- estado local (fallback demo se Supabase não configurado) ---- */
let DB = {
  clientes: [],
  ferramentas: [],
  locacoes: [],
  itens_locacao: [],
  pagamentos: []
};

const EMPRESA = {
  nome: 'Base Forte Locação — Grupo Munick Engenharia',
  cnpj: '',
  telefone: '(11) 98942-8173',
  email: 'munick@munickengenharia.com.br',
  endereco: 'Santana de Parnaíba, SP'
};

function toast(msg, ok=true){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.borderLeftColor = ok ? 'var(--amber)' : 'var(--red)';
  t.style.display = 'block';
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(()=> t.style.display='none', 2600);
}

function fmtMoney(v){ return 'R$ ' + Number(v||0).toLocaleString('pt-BR',{minimumFractionDigits:2, maximumFractionDigits:2}); }
function fmtDate(d){ if(!d) return '-'; const dt = new Date(d+'T00:00:00'); return dt.toLocaleDateString('pt-BR'); }
function todayISO(){ return new Date().toISOString().slice(0,10); }
function uid(){ return 'id-'+Math.random().toString(36).slice(2,10); }

/* ======================================================
   CARREGAMENTO DE DADOS
   ====================================================== */
async function loadAll(){
  if(supaOk){
    try{
      const [c,f,l,i,p] = await Promise.all([
        supabaseClient.from('clientes').select('*').order('criado_em',{ascending:false}),
        supabaseClient.from('ferramentas').select('*').order('criado_em',{ascending:false}),
        supabaseClient.from('locacoes').select('*').order('criado_em',{ascending:false}),
        supabaseClient.from('itens_locacao').select('*'),
        supabaseClient.from('pagamentos').select('*')
      ]);
      DB.clientes = c.data || [];
      DB.ferramentas = f.data || [];
      DB.locacoes = l.data || [];
      DB.itens_locacao = i.data || [];
      DB.pagamentos = p.data || [];
    }catch(e){ console.error(e); toast('Erro ao carregar do Supabase — usando modo local', false); }
  }
}

/* ======================================================
   NAVEGAÇÃO
   ====================================================== */
const titles = {
  dashboard:'Dashboard', clientes:'Clientes', ferramentas:'Ferramentas',
  'nova-locacao':'Nova Locação', locacoes:'Locações'
};
document.querySelectorAll('.nav-btn').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    const view = btn.dataset.view;
    document.getElementById('page-title').textContent = titles[view];
    render(view);
  });
});

async function render(view){
  const el = document.getElementById('content');
  el.innerHTML = '<div class="empty">Carregando…</div>';
  await loadAll();
  if(view === 'dashboard') renderDashboard(el);
  else if(view === 'clientes') renderClientes(el);
  else if(view === 'ferramentas') renderFerramentas(el);
  else if(view === 'nova-locacao') renderNovaLocacao(el);
  else if(view === 'locacoes') renderLocacoes(el);
}

/* ======================================================
   CONFIG NOTE (se supabase não estiver configurado)
   ====================================================== */
function configNote(){
  if(supaOk) return '';
  return `<div class="config-note">⚠ Supabase ainda não configurado — edite <span class="mono">SUPABASE_URL</span> e <span class="mono">SUPABASE_ANON_KEY</span> no topo do arquivo. Rodando em modo demonstração (dados não são salvos).</div>`;
}

/* ======================================================
   DASHBOARD
   ====================================================== */
function renderDashboard(el){
  const ativas = DB.locacoes.filter(l=>l.status==='ativa');
  const atrasadas = DB.locacoes.filter(l=> l.status==='ativa' && l.data_devolucao_prevista < todayISO());
  const disponiveis = DB.ferramentas.reduce((s,f)=>s+(f.quantidade_disponivel||0),0);
  const mesAtual = new Date().toISOString().slice(0,7);
  const faturamentoMes = DB.pagamentos.filter(p=> (p.data_pagamento||'').slice(0,7)===mesAtual && p.tipo==='pagamento')
    .reduce((s,p)=>s+Number(p.valor||0),0);

  el.innerHTML = `
    ${configNote()}
    <div class="grid grid-4" style="margin-bottom:20px;">
      <div class="stat"><div class="num mono">${ativas.length}</div><div class="lbl">Locações ativas</div></div>
      <div class="stat warn"><div class="num mono">${atrasadas.length}</div><div class="lbl">Devoluções atrasadas</div></div>
      <div class="stat ok"><div class="num mono">${disponiveis}</div><div class="lbl">Itens disponíveis</div></div>
      <div class="stat"><div class="num mono">${fmtMoney(faturamentoMes)}</div><div class="lbl">Faturamento do mês</div></div>
    </div>
    <div class="panel">
      <h2>Locações em andamento</h2>
      ${ativas.length ? tableLocacoes(ativas) : `<div class="empty"><div class="display">Nenhuma locação ativa</div>Comece criando uma nova locação.</div>`}
    </div>
  `;
}

function tableLocacoes(list){
  return `<table><thead><tr><th>Nº</th><th>Cliente</th><th>Retirada</th><th>Devolução prevista</th><th>Valor</th><th>Status</th><th></th></tr></thead><tbody>
    ${list.map(l=>{
      const cliente = DB.clientes.find(c=>c.id===l.cliente_id);
      const atrasada = l.status==='ativa' && l.data_devolucao_prevista < todayISO();
      const badge = atrasada ? '<span class="badge badge-bad">Atrasada</span>' :
        l.status==='devolvida' ? '<span class="badge badge-neutral">Devolvida</span>' :
        l.status==='cancelada' ? '<span class="badge badge-neutral">Cancelada</span>' :
        '<span class="badge badge-ok">Ativa</span>';
      return `<tr>
        <td class="mono">#${l.numero||'-'}</td>
        <td>${cliente ? cliente.nome : '—'}</td>
        <td>${fmtDate(l.data_retirada)}</td>
        <td>${fmtDate(l.data_devolucao_prevista)}</td>
        <td class="mono">${fmtMoney(l.valor_total)}</td>
        <td>${badge}</td>
        <td><button class="btn btn-outline btn-sm" onclick="verLocacao('${l.id}')">Ver</button></td>
      </tr>`;
    }).join('')}
  </tbody></table>`;
}

/* ======================================================
   CLIENTES
   ====================================================== */
function renderClientes(el){
  el.innerHTML = `
    ${configNote()}
    <div class="grid grid-2">
      <div class="panel">
        <h2 id="form-cliente-titulo">Novo cliente</h2>
        <form id="form-cliente">
          <input type="hidden" id="cli-id" value="">
          <div class="field"><label>Tipo</label>
            <select id="cli-tipo"><option value="fisica">Pessoa física</option><option value="juridica">Pessoa jurídica</option></select>
          </div>
          <div class="field"><label>Nome / Razão social</label><input id="cli-nome" required></div>
          <div class="field"><label>CPF / CNPJ</label><input id="cli-doc" required></div>
          <div class="row">
            <div class="field"><label>Telefone</label><input id="cli-tel" placeholder="(11) 99999-9999"></div>
            <div class="field"><label>E-mail</label><input id="cli-email" type="email"></div>
          </div>
          <div class="field"><label>Endereço</label><input id="cli-end"></div>
          <div class="field"><label>Status</label>
            <select id="cli-status"><option value="ativo">Ativo</option><option value="inadimplente">Inadimplente</option><option value="bloqueado">Bloqueado</option></select>
          </div>
          <div class="field"><label>Observações</label><textarea id="cli-obs" rows="2"></textarea></div>
          <div style="display:flex; gap:10px;">
            <button type="submit" class="btn btn-primary" id="cli-submit-btn">Cadastrar cliente</button>
            <button type="button" class="btn btn-outline hidden" id="cli-cancel-btn" onclick="cancelarEdicaoCliente()">Cancelar edição</button>
          </div>
        </form>
      </div>
      <div class="panel">
        <h2>Clientes cadastrados <span class="tag">${DB.clientes.length}</span></h2>
        <div class="field"><input id="busca-cliente" placeholder="Buscar por nome ou documento..." oninput="filtrarClientes()"></div>
        <div id="lista-clientes">${listaClientesHTML(DB.clientes)}</div>
      </div>
    </div>
  `;
  document.getElementById('form-cliente').addEventListener('submit', async (e)=>{
    e.preventDefault();
    const id = document.getElementById('cli-id').value;
    const dados = {
      tipo_pessoa: document.getElementById('cli-tipo').value,
      nome: document.getElementById('cli-nome').value,
      documento: document.getElementById('cli-doc').value,
      telefone: document.getElementById('cli-tel').value,
      email: document.getElementById('cli-email').value,
      endereco: document.getElementById('cli-end').value,
      observacoes: document.getElementById('cli-obs').value,
      status: document.getElementById('cli-status').value
    };
    if(id){
      if(supaOk){
        const {error} = await supabaseClient.from('clientes').update(dados).eq('id', id);
        if(error){ toast('Erro ao atualizar cliente', false); console.error(error); return; }
      } else {
        const c = DB.clientes.find(x=>x.id===id);
        Object.assign(c, dados);
      }
      toast('Cliente atualizado');
    } else {
      if(supaOk){
