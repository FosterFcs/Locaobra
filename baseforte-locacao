function adicionarItem(){
  const sel = document.getElementById('add-ferramenta');
  const qtd = Number(document.getElementById('add-qtd').value);
  if(!sel.value){ toast('Selecione uma ferramenta', false); return; }
  const existente = carrinho.find(i=>i.ferramenta_id===sel.value);
  if(existente){ existente.quantidade += qtd; }
  else { carrinho.push({ferramenta_id: sel.value, quantidade: qtd}); }
  renderCarrinho();
  calcularResumo();
}

function removerItem(fid){
  carrinho = carrinho.filter(i=>i.ferramenta_id!==fid);
  renderCarrinho();
  calcularResumo();
}

function renderCarrinho(){
  const box = document.getElementById('carrinho-list');
  if(!carrinho.length){ box.innerHTML = '<div class="empty" style="padding:16px;">Nenhuma ferramenta adicionada ainda</div>'; return; }
  box.innerHTML = `<table><thead><tr><th>Ferramenta</th><th>Qtd</th><th></th></tr></thead><tbody>
    ${carrinho.map(i=>{
      const f = DB.ferramentas.find(x=>x.id===i.ferramenta_id);
      return `<tr><td>${f?f.nome:'?'}</td><td class="mono">${i.quantidade}</td>
      <td><button class="btn btn-danger btn-sm" onclick="removerItem('${i.ferramenta_id}')">Remover</button></td></tr>`;
    }).join('')}
  </tbody></table>`;
}

function calcularPeriodo(){
  const r = document.getElementById('loc-retirada').value;
  const d = document.getElementById('loc-devolucao').value;
  if(!r || !d) return {dias:0};
  const dias = Math.max(1, Math.round((new Date(d) - new Date(r)) / 86400000));
  return {dias};
}

function calcularItemValor(f, tipo, dias){
  if(!f) return 0;
  if(tipo==='diaria') return f.valor_diaria * dias;
  if(tipo==='semanal'){
    const semanas = Math.ceil(dias/7);
    const vSemana = f.valor_semanal || (f.valor_diaria*5);
    return vSemana * semanas;
  }
  if(tipo==='mensal'){
    const meses = Math.ceil(dias/30);
    const vMes = f.valor_mensal || (f.valor_diaria*22);
    return vMes * meses;
  }
  return 0;
}

function calcularResumo(){
  const box = document.getElementById('resumo');
  if(!box) return;
  const tipo = document.getElementById('loc-tipo').value;
  const {dias} = calcularPeriodo();
  const caucao = Number(document.getElementById('loc-caucao').value || 0);

  let total = 0;
  const linhas = carrinho.map(i=>{
    const f = DB.ferramentas.find(x=>x.id===i.ferramenta_id);
    const subtotal = calcularItemValor(f, tipo, dias) * i.quantidade;
    total += subtotal;
    return `<div class="row" style="font-size:13.5px; color:#C9CCD1;"><span>${f?f.nome:'?'} × ${i.quantidade}</span><span class="mono">${fmtMoney(subtotal)}</span></div>`;
  }).join('');

  box.innerHTML = `
    <div class="summary-box">
      <div style="font-family:'Oswald',sans-serif; text-transform:uppercase; font-size:13px; color:#9CA0A8; margin-bottom:8px;">
        Período: ${dias} dia(s) · Cobrança ${tipo}
      </div>
      ${linhas || '<div style="color:#9CA0A8; font-size:13.5px;">Adicione ferramentas acima</div>'}
      <div class="row" style="margin-top:10px; border-top:1px solid #3A3D42; padding-top:10px;">
        <span>Caução</span><span class="mono">${fmtMoney(caucao)}</span>
      </div>
      <div class="row" style="margin-top:6px;">
        <span style="font-family:'Oswald',sans-serif; text-transform:uppercase;">Total da locação</span>
        <span class="total">${fmtMoney(total)}</span>
      </div>
    </div>
    <div style="margin-top:16px; display:flex; gap:10px;">
      <button class="btn btn-primary" onclick="salvarLocacao()">Confirmar locação</button>
    </div>
  `;
  window._locTotal = total;
}

async function salvarLocacao(){
  const clienteId = document.getElementById('loc-cliente').value;
  if(!clienteId){ toast('Selecione um cliente', false); return; }
  if(!carrinho.length){ toast('Adicione ao menos uma ferramenta', false); return; }

  const tipo = document.getElementById('loc-tipo').value;
  const retirada = document.getElementById('loc-retirada').value;
  const devolucao = document.getElementById('loc-devolucao').value;
  const caucao = Number(document.getElementById('loc-caucao').value || 0);
  const {dias} = calcularPeriodo();

  const locacaoObj = {
    cliente_id: clienteId,
    data_retirada: retirada,
    data_devolucao_prevista: devolucao,
    tipo_cobranca: tipo,
    valor_total: window._locTotal || 0,
    valor_caucao: caucao,
    status: 'ativa'
  };

  let locacaoId, numero;
  if(supaOk){
    const {data, error} = await supabaseClient.from('locacoes').insert(locacaoObj).select().single();
    if(error){ toast('Erro ao salvar locação', false); console.error(error); return; }
    locacaoId = data.id; numero = data.numero;
    const itens = carrinho.map(i=>{
      const f = DB.ferramentas.find(x=>x.id===i.ferramenta_id);
      const valorUnit = calcularItemValor(f, tipo, dias);
      return {locacao_id: locacaoId, ferramenta_id: i.ferramenta_id, quantidade: i.quantidade, valor_unitario: valorUnit, subtotal: valorUnit*i.quantidade};
    });
    const {error:e2} = await supabaseClient.from('itens_locacao').insert(itens);
    if(e2) console.error(e2);
    if(caucao > 0){
      await supabaseClient.from('pagamentos').insert({locacao_id: locacaoId, tipo:'caucao', valor: caucao, forma_pagamento:'a definir'});
    }
  } else {
    locacaoId = uid(); numero = DB.locacoes.length + 1;
    locacaoObj.id = locacaoId; locacaoObj.numero = numero; locacaoObj.criado_em = new Date().toISOString();
    DB.locacoes.unshift(locacaoObj);
    carrinho.forEach(i=>{
      const f = DB.ferramentas.find(x=>x.id===i.ferramenta_id);
      const valorUnit = calcularItemValor(f, tipo, dias);
      DB.itens_locacao.push({id:uid(), locacao_id: locacaoId, ferramenta_id:i.ferramenta_id, quantidade:i.quantidade, valor_unitario:valorUnit, subtotal:valorUnit*i.quantidade});
      f.quantidade_disponivel -= i.quantidade;
    });
  }

  toast('Locação registrada! Gerando contrato...');
  await loadAll();
  const locFinal = supaOk ? DB.locacoes.find(l=>l.id===locacaoId) : locacaoObj;
  gerarContratoPDF(locFinal);
  document.querySelector('[data-view="locacoes"]').click();
}

/* ======================================================
   LOCAÇÕES (lista + ações)
   ====================================================== */
function renderLocacoes(el){
  el.innerHTML = `
    ${configNote()}
    <div class="panel">
      <h2>Todas as locações <span class="tag">${DB.locacoes.length}</span></h2>
      <div class="row" style="margin-bottom:14px;">
        <div class="field" style="margin-bottom:0;"><input id="busca-locacao" placeholder="Buscar por cliente ou número..." oninput="filtrarLocacoes()"></div>
        <div class="field" style="margin-bottom:0; max-width:200px;">
          <select id="filtro-status-locacao" onchange="filtrarLocacoes()">
            <option value="">Todos os status</option>
            <option value="ativa">Ativas</option>
            <option value="atrasada">Atrasadas</option>
            <option value="devolvida">Devolvidas</option>
            <option value="cancelada">Canceladas</option>
          </select>
        </div>
      </div>
      <div id="lista-locacoes">${DB.locacoes.length ? tableLocacoesCompleta(DB.locacoes) : `<div class="empty"><div class="display">Nenhuma locação registrada</div></div>`}</div>
    </div>
  `;
}

function filtrarLocacoes(){
  const termo = document.getElementById('busca-locacao').value.toLowerCase();
  const statusFiltro = document.getElementById('filtro-status-locacao').value;
  const filtrados = DB.locacoes.filter(l=>{
    const cliente = DB.clientes.find(c=>c.id===l.cliente_id);
    const nomeMatch = (cliente?.nome||'').toLowerCase().includes(termo) || String(l.numero||'').includes(termo);
    const atrasada = l.status==='ativa' && l.data_devolucao_prevista < todayISO();
    const statusReal = atrasada ? 'atrasada' : l.status;
    const statusMatch = !statusFiltro || statusReal === statusFiltro;
    return nomeMatch && statusMatch;
  });
  document.getElementById('lista-locacoes').innerHTML = filtrados.length ? tableLocacoesCompleta(filtrados) : `<div class="empty"><div class="display">Nenhuma locação encontrada</div></div>`;
}

function tableLocacoesCompleta(list){
  return `<table><thead><tr><th>Nº</th><th>Cliente</th><th>Retirada</th><th>Devolução prev.</th><th>Valor</th><th>Status</th><th>Ações</th></tr></thead><tbody>
    ${list.map(l=>{
      const cliente = DB.clientes.find(c=>c.id===l.cliente_id);
      const atrasada = l.status==='ativa' && l.data_devolucao_prevista < todayISO();
      const badge = l.status==='devolvida' ? '<span class="badge badge-neutral">Devolvida</span>' :
        atrasada ? '<span class="badge badge-bad">Atrasada</span>' :
        l.status==='cancelada' ? '<span class="badge badge-neutral">Cancelada</span>' :
        '<span class="badge badge-ok">Ativa</span>';
      return `<tr>
        <td class="mono">#${l.numero||'-'}</td>
        <td>${cliente?cliente.nome:'—'}</td>
        <td>${fmtDate(l.data_retirada)}</td>
        <td>${fmtDate(l.data_devolucao_prevista)}</td>
        <td class="mono">${fmtMoney(l.valor_total)}</td>
        <td>${badge}</td>
        <td class="actions-cell">
          <button class="btn btn-outline btn-sm" onclick="gerarContratoPDF(${JSON.stringify(l).replace(/"/g,'&quot;')})">Contrato</button>
          <button class="btn btn-outline btn-sm" onclick="gerarReciboPDF(${JSON.stringify(l).replace(/"/g,'&quot;')})">Recibo</button>
          <button class="btn btn-outline btn-sm" onclick="gerarTermoPDF(${JSON.stringify(l).replace(/"/g,'&quot;')}, 'retirada')">Termo Retirada</button>
          ${l.status==='devolvida' ? `<button class="btn btn-outline btn-sm" onclick="gerarTermoPDF(${JSON.stringify(l).replace(/"/g,'&quot;')}, 'devolucao')">Termo Devolução</button>` : ''}
          ${l.status==='ativa' ? `<button class="btn btn-outline btn-sm" onclick="lembreteWhatsapp('${l.id}')">WhatsApp</button>` : ''}
          ${l.status==='ativa' ? `<button class="btn btn-primary btn-sm" onclick="marcarDevolvida('${l.id}')">Devolver</button>` : ''}
        </td>
      </tr>`;
    }).join('')}
  </tbody></table>`;
}

function calcularMulta(locacaoId, diasAtraso){
  if(diasAtraso <= 0) return 0;
  const itens = DB.itens_locacao.filter(i=>i.locacao_id===locacaoId);
  let multaDia = 0;
  itens.forEach(i=>{
    const f = DB.ferramentas.find(x=>x.id===i.ferramenta_id);
    if(f) multaDia += (f.valor_diaria || 0) * i.quantidade;
  });
  return multaDia * diasAtraso;
}

async function marcarDevolvida(id){
  const hoje = todayISO();
  const loc = DB.locacoes.find(x=>x.id===id);
  const diasAtraso = loc ? Math.max(0, Math.round((new Date(hoje) - new Date(loc.data_devolucao_prevista)) / 86400000)) : 0;
  const multa = calcularMulta(id, diasAtraso);

  if(supaOk){
    const {error} = await supabaseClient.from('locacoes').update({status:'devolvida', data_devolucao_real: hoje, valor_multa: multa}).eq('id', id);
    if(error){ toast('Erro ao atualizar', false); return; }
    // devolve estoque
    const itens = DB.itens_locacao.filter(i=>i.locacao_id===id);
    for(const i of itens){
      const f = DB.ferramentas.find(x=>x.id===i.ferramenta_id);
      if(f) await supabaseClient.from('ferramentas').update({quantidade_disponivel: f.quantidade_disponivel + i.quantidade}).eq('id', f.id);
    }
    if(multa > 0){
      await supabaseClient.from('pagamentos').insert({locacao_id: id, tipo:'multa', valor: multa, observacoes: `Multa por ${diasAtraso} dia(s) de atraso`});
    }
  } else {
    loc.status='devolvida'; loc.data_devolucao_real=hoje; loc.valor_multa=multa;
    DB.itens_locacao.filter(i=>i.locacao_id===id).forEach(i=>{
      const f = DB.ferramentas.find(x=>x.id===i.ferramenta_id);
      if(f) f.quantidade_disponivel += i.quantidade;
    });
  }
  toast(multa > 0 ? `Devolução registrada com multa de ${fmtMoney(multa)} (${diasAtraso} dia(s) de atraso)` : 'Devolução registrada, estoque atualizado');
  render('locacoes');
}

function lembreteWhatsapp(id){
  const loc = DB.locacoes.find(x=>x.id===id);
  const cliente = DB.clientes.find(c=>c.id===loc.cliente_id);
  if(!cliente || !cliente.telefone){ toast('Cliente sem telefone cadastrado', false); return; }
  const itens = DB.itens_locacao.filter(i=>i.locacao_id===id);
  const nomesFerramentas = itens.map(i=>{
    const f = DB.ferramentas.find(x=>x.id===i.ferramenta_id);
    return f ? f.nome : '';
  }).filter(Boolean).join(', ');
  const atrasada = loc.data_devolucao_prevista < todayISO();
  const msg = atrasada
    ? `Olá, ${cliente.nome}! A devolução de ${nomesFerramentas} estava prevista para ${fmtDate(loc.data_devolucao_prevista)} e consta em atraso. Poderia nos dar um retorno sobre a devolução? — ${EMPRESA.nome}`
    : `Olá, ${cliente.nome}! Passando para lembrar que a devolução de ${nomesFerramentas} está prevista para ${fmtDate(loc.data_devolucao_prevista)}. Qualquer dúvida, estamos à disposição. — ${EMPRESA.nome}`;
  const digitos = (cliente.telefone || '').replace(/\D/g, '');
  const numeroCompleto = digitos.startsWith('55') ? digitos : `55${digitos}`;
  window.open(`https://wa.me/${numeroCompleto}?text=${encodeURIComponent(msg)}`, '_blank');
}

