/* ======================================================
   PAPEL TIMBRADO — cabeçalho e rodapé padrão de todos os PDFs
   ====================================================== */
function desenharCabecalhoPDF(doc, titulo, subtitulo){
  // faixa preta no topo (fundo da marca)
  doc.setFillColor(20, 20, 20);
  doc.rect(0, 0, 210, 20, 'F');

  // logo real embutido no app
  try{
    const logoImg = document.querySelector('.logo-mark-sm-img') || document.querySelector('.logo-mark-img');
    if(logoImg && logoImg.src){
      doc.addImage(logoImg.src, 'JPEG', 8, 3, 26, 14);
    }
  }catch(e){ console.error('logo pdf', e); }

  doc.setFont('helvetica','normal'); doc.setFontSize(7.5);
  doc.setTextColor(255,255,255);
  doc.text(EMPRESA.nome, 195, 8, {align:'right'});
  doc.text(`${EMPRESA.telefone}  ·  ${EMPRESA.email}`, 195, 13, {align:'right'});

  // linha tricolor (assinatura visual da marca)
  doc.setFillColor(76,154,28); doc.rect(0, 20, 70, 1.6, 'F');
  doc.setFillColor(219,27,22); doc.rect(70, 20, 70, 1.6, 'F');
  doc.setFillColor(29,63,115); doc.rect(140, 20, 70, 1.6, 'F');

  doc.setTextColor(0,0,0);
  let y = 30;
  doc.setFont('helvetica','bold'); doc.setFontSize(15);
  doc.text(titulo, 105, y, {align:'center'}); y+=6;
  if(subtitulo){
    doc.setFont('helvetica','normal'); doc.setFontSize(10);
    doc.text(subtitulo, 105, y, {align:'center'}); y+=8;
  } else {
    y+=4;
  }
  return y;
}

function desenharRodapePDF(doc){
  const pageCount = doc.internal.getNumberOfPages();
  for(let i=1; i<=pageCount; i++){
    doc.setPage(i);
    doc.setDrawColor(220,220,220); doc.setLineWidth(0.2);
    doc.line(15, 282, 195, 282);
    doc.setFont('helvetica','normal'); doc.setFontSize(7.5);
    doc.setTextColor(140,140,140);
    doc.text('Desenvolvido por Foster Engenharia & Construção', 15, 288);
    doc.text(`Página ${i} de ${pageCount}`, 195, 288, {align:'right'});
    doc.setTextColor(0,0,0);
  }
}

